{% stylesheet %}
  .test-section {
    background-color: #f0f0f0;
    padding: 20px;
    border-radius: 5px;
  }

  .test-section .block {
    margin-bottom: 15px;
    padding: 10px;
    background-color: #fff;
    border: 1px solid #ddd;
    border-radius: 3px;
  }
{% endstylesheet %}

<div class="test-section">
  <h1>{{ section.settings.title }}</h1>
  <p>{{ section.settings.text }}</p>
  <img
    src="{{ section.settings.image_url | img_url: 'medium' }}"
    alt="{{ section.settings.title }}"
    width="300"
    height="200"
  >

  {% if section.settings.text %}
    <p>{{ section.settings.text }}</p>
  {% endif %}

  {% if section.settings.textarea %}
    <p>{{ section.settings.textarea }}</p>
  {% endif %}

  {% if section.blocks.size > 0 %}
    {% for block in section.blocks %}
      <div class="block">
        <h3>{{ block.settings.item_text }}</h3>
        <p>{{ block.settings.item_description }}</p>
      </div>
    {% endfor %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Test Section",
  "tag": "section",
  "class": "page-width",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Test Section Title"
    },
    {
      "type": "image_picker",
      "id": "image_url",
      "label": "Image"
    },
    {
      "type": "textarea",
      "id": "textarea",
      "label": "Test Section area text",
      "default": "This is a test section with customizable content."
    }
  ],
  "blocks": [
    {
      "type": "itemblock",
      "name": "Item Block",
      "settings": [
        {
          "type": "text",
          "id": "item_text",
          "label": "Item Text",
          "default": "Default Item Text"
        },
        {
          "type": "textarea",
          "id": "item_description",
          "label": "Item Description",
          "default": "This is a description for the item block."
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Test Section",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
